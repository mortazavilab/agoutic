# AGOUTIC Environment Configuration
# Configure MCP servers to connect to remote watson server instead of localhost
#
# IMPORTANT: Load these variables before running any AGOUTIC commands:
#   source load_env.sh
#
# Set the Watson host and MCP URLs below for your environment

# Watson server IP: 128.200.7.223 (dhcp-7-223.bio.uci.edu)
WATSON_HOST=128.200.7.223

# MCP Server URLs - all running on watson
ENCODE_MCP_URL=http://128.200.7.223:8006
SERVER3_MCP_URL=http://128.200.7.223:8002
SERVER4_MCP_URL=http://128.200.7.223:8005

# Optional: LLM configuration if running remotely
# LLM_URL=http://${WATSON_HOST}:11434/v1

# Optional: Frontend URL for OAuth redirects
# FRONTEND_URL=http://localhost:8501

# Optional: Google OAuth configuration
# GOOGLE_CLIENT_ID=your_client_id
# GOOGLE_CLIENT_SECRET=your_client_secret
# GOOGLE_REDIRECT_URI=http://localhost:8000/auth/callback